# ========================
# Agentic Flow — Environment Variables
# ========================

# === LLM Provider (GLM via z.ai — Anthropic-compatible) ===
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://api.z.ai/api/anthropic
GLM_MODEL=glm-5-turbo

# === Telegram Gateway (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS_STR=

# === Database ===
DATABASE_URL=sqlite:///./agentic_flow.db

# === Security ===
API_KEY_ENABLED=false
API_KEY=change_me_for_production_use
ALLOWED_ORIGINS_STR=http://localhost:5173
